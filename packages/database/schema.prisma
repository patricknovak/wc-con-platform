generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  MANAGER
  DISPATCHER
  VIEWER
}

enum CustomerType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  GOVERNMENT
}

enum QuoteStatus {
  DRAFT
  AI_GENERATED
  PENDING_REVIEW
  APPROVED
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum CallIntent {
  QUOTE_REQUEST
  INFORMATION
  DISPATCH_URGENT
  COMPLAINT
  FOLLOW_UP
  OTHER
}

enum CallPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CallStatus {
  NEW
  REVIEWED
  ACTIONED
  ARCHIVED
}

enum OpportunitySource {
  APC
  MERX
  CONSTRUCT_CONNECT
  MUNICIPAL
  ALBERTA_GOV
  MANUAL
}

enum OpportunityStatus {
  NEW
  STRONG_MATCH
  REVIEWING
  PURSUING
  PROPOSAL_DRAFTED
  SUBMITTED
  WON
  LOST
  EXPIRED
  ARCHIVED
}

enum ProposalStatus {
  DRAFTING
  AI_GENERATED
  UNDER_REVIEW
  FINALIZED
  SUBMITTED
  WON
  LOST
}

enum HubListingTier {
  FREE
  FEATURED
  PREMIUM
}

enum HubBusinessStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum DocumentType {
  QUOTE
  RFP
  PROPOSAL
  SUBMISSION
  INVOICE
  CONTRACT
  OTHER
}

enum ProductCategory {
  AGGREGATE
  LANDSCAPING
  CONCRETE
  EQUIPMENT
}

// --- WORK ORDER LIFECYCLE ENUMS ---

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT_TO_CUSTOMER
  ACCEPTED
  REJECTED
  CANCELLED
}

enum WorkOrderStatus {
  PENDING
  SCHEDULED
  DISPATCHED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  RUSH
}

enum TicketStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DISPUTED
  REVISED
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  WRITTEN_OFF
}

enum PaymentMethod {
  CHEQUE
  E_TRANSFER
  CREDIT_CARD
  CASH
  WIRE
  OTHER
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

enum EquipmentType {
  TRUCK
  TRAILER
  EXCAVATOR
  LOADER
  CRUSHER
  SKID_STEER
  GRADER
  COMPACTOR
  OTHER
}

enum DriverStatus {
  ACTIVE
  OFF_DUTY
  ON_LEAVE
  TERMINATED
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(VIEWER)
  phone     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvedQuotes    Quote[]        @relation("ApprovedBy")
  callActions       CallAction[]
  approvedPOs       PurchaseOrder[] @relation("POApprovedBy")
  createdWorkOrders WorkOrder[]     @relation("WOCreatedBy")
  reviewedTickets   Ticket[]        @relation("TicketReviewedBy")
  approvedInvoices  Invoice[]       @relation("InvoiceApprovedBy")
}

// ============================================================
// CORE BUSINESS
// ============================================================

model Customer {
  id            String       @id @default(cuid())
  name          String
  email         String?
  phone         String
  company       String?
  type          CustomerType @default(RESIDENTIAL)
  address       String?
  city          String?
  province      String?      @default("AB")
  postalCode    String?
  notes         String?
  lifetimeValue Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  quotes         Quote[]
  phoneCalls     PhoneCall[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  payments       Payment[]

  @@index([type])
  @@index([city])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  category    ProductCategory
  description String?
  specs       String?
  sizeRange   String?
  commonUses  String?
  priceRange  String?
  unitOfMeasure String        @default("tonne")
  imageUrl    String?
  inStock     Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  quoteItems     QuoteItem[]
  workOrderItems WorkOrderItem[]
  ticketItems    TicketItem[]

  @@index([category])
}

model ServiceArea {
  id                String  @id @default(cuid())
  name              String
  description       String?
  deliverySurcharge Float   @default(0)
  polygon           Json?
  isActive          Boolean @default(true)
}

model Quote {
  id              String      @id @default(cuid())
  quoteNumber     String      @unique
  customer        Customer    @relation(fields: [customerId], references: [id])
  customerId      String
  status          QuoteStatus @default(DRAFT)
  subtotal        Float       @default(0)
  deliveryFee     Float       @default(0)
  tax             Float       @default(0)
  total           Float       @default(0)
  deliveryAddress String?
  deliveryCity    String?
  deliveryDistance Float?
  notes           String?
  aiDraft         String?
  approvedBy      User?       @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedById    String?
  approvedAt      DateTime?
  sentAt          DateTime?
  expiresAt       DateTime?
  pdfUrl          String?
  source          String?     @default("web")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items          QuoteItem[]
  purchaseOrders PurchaseOrder[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model QuoteItem {
  id        String  @id @default(cuid())
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Float
  unitPrice Float
  total     Float
  notes     String?

  @@index([quoteId])
}

// ============================================================
// VOICE AGENT (ElevenLabs + Twilio)
// ============================================================

model PhoneCall {
  id              String       @id @default(cuid())
  callerPhone     String
  callerName      String?
  callerEmail     String?
  callerCompany   String?
  intent          CallIntent   @default(OTHER)
  priority        CallPriority @default(MEDIUM)
  status          CallStatus   @default(NEW)
  transcript      String?
  summary         String?
  extractedData   Json?
  duration        Int?
  recordingUrl    String?
  agentId         String?
  twilioCallSid   String?      @unique
  customer        Customer?    @relation(fields: [customerId], references: [id])
  customerId      String?
  transferredToHuman Boolean   @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  actions CallAction[]

  @@index([status])
  @@index([intent])
  @@index([createdAt])
  @@index([callerPhone])
}

model CallAction {
  id          String   @id @default(cuid())
  call        PhoneCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  callId      String
  actionType  String
  description String?
  assignedTo  User?    @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([callId])
}

// ============================================================
// BUSINESS HUB
// ============================================================

model HubCategory {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  icon        String?
  sortOrder   Int           @default(0)
  businesses  HubBusiness[]
}

model HubBusiness {
  id            String            @id @default(cuid())
  name          String
  slug          String            @unique
  description   String?
  longDescription String?
  logoUrl       String?
  coverImageUrl String?
  phone         String?
  email         String?
  website       String?
  address       String?
  city          String?           @default("Hinton")
  province      String?           @default("AB")
  serviceAreas  String[]
  category      HubCategory       @relation(fields: [categoryId], references: [id])
  categoryId    String
  tier          HubListingTier    @default(FREE)
  status        HubBusinessStatus @default(PENDING)
  featured      Boolean           @default(false)
  referralCode  String?           @unique
  contactName   String?
  approvedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  referralsOut HubReferral[] @relation("SourceBusiness")
  referralsIn  HubReferral[] @relation("DestinationBusiness")

  @@index([status])
  @@index([categoryId])
  @@index([featured])
  @@index([city])
}

model HubReferral {
  id            String       @id @default(cuid())
  source        HubBusiness  @relation("SourceBusiness", fields: [sourceId], references: [id])
  sourceId      String
  destination   HubBusiness  @relation("DestinationBusiness", fields: [destinationId], references: [id])
  destinationId String
  visitorId     String?
  converted     Boolean      @default(false)
  revenue       Float?
  createdAt     DateTime     @default(now())

  @@index([sourceId])
  @@index([destinationId])
  @@index([createdAt])
}

// ============================================================
// OPPORTUNITY ENGINE
// ============================================================

model Opportunity {
  id              String            @id @default(cuid())
  externalId      String?           @unique
  source          OpportunitySource
  title           String
  description     String?
  fullText        String?
  category        String?
  location        String?
  estimatedValue  Float?
  deadline        DateTime?
  publishedAt     DateTime?
  documentUrl     String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  matchScore      Int               @default(0)
  scoreBreakdown  Json?
  capabilityTags  String[]
  status          OpportunityStatus @default(NEW)
  notifiedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  proposals Proposal[]

  @@index([status])
  @@index([matchScore])
  @@index([deadline])
  @@index([source])
  @@index([createdAt])
}

model Proposal {
  id            String         @id @default(cuid())
  opportunity   Opportunity    @relation(fields: [opportunityId], references: [id])
  opportunityId String
  status        ProposalStatus @default(DRAFTING)
  aiDraft       String?
  finalVersion  String?
  coverLetter   String?
  pdfUrl        String?
  submittedAt   DateTime?
  outcome       String?
  outcomeNotes  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([opportunityId])
  @@index([status])
}

// ============================================================
// INTELLIGENCE LAYER
// ============================================================

model HistoricalDocument {
  id            String       @id @default(cuid())
  type          DocumentType
  fileName      String
  fileUrl       String?
  fileSize      Int?
  extractedData Json?
  extractedText String?
  embedding     Unsupported("vector(1536)")?
  processedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([type])
}

model PricingDataPoint {
  id           String   @id @default(cuid())
  productName  String
  productCategory String?
  quantity     Float
  unitPrice    Float
  totalPrice   Float?
  distance     Float?
  customerName String?
  customerType CustomerType?
  date         DateTime
  outcome      String?
  source       String?
  createdAt    DateTime @default(now())

  @@index([productName])
  @@index([date])
  @@index([outcome])
}

// ============================================================
// CONTENT
// ============================================================

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  client      String?
  location    String?
  category    String?
  services    String[]
  images      String[]
  featured    Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
  @@index([category])
}

model Testimonial {
  id          String   @id @default(cuid())
  authorName  String
  authorTitle String?
  company     String?
  content     String
  rating      Int?     @default(5)
  featured    Boolean  @default(false)
  imageUrl    String?
  createdAt   DateTime @default(now())

  @@index([featured])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String?  @default("WC-CON Team")
  tags        String[]
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([publishedAt])
}

// ============================================================
// NOTIFICATIONS & ACTIVITY
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  data      Json?
  read      Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  @@index([read])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// DRIVERS & EQUIPMENT
// ============================================================

model Driver {
  id            String       @id @default(cuid())
  name          String
  phone         String       @unique
  email         String?
  licenseClass  String?
  licenseExpiry DateTime?
  status        DriverStatus @default(ACTIVE)
  hourlyRate    Float?
  overtimeRate  Float?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workOrders WorkOrder[]
  tickets    Ticket[]

  @@index([status])
  @@index([phone])
}

model Equipment {
  id            String          @id @default(cuid())
  name          String
  type          EquipmentType
  unitNumber    String          @unique
  make          String?
  model         String?
  year          Int?
  licensePlate  String?
  status        EquipmentStatus @default(AVAILABLE)
  hourlyRate    Float?
  dailyRate     Float?
  kmRate        Float?
  currentKm     Float?
  lastServiceAt DateTime?
  nextServiceAt DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  workOrders     WorkOrder[]
  ticketEquipment TicketEquipmentUsage[]

  @@index([status])
  @@index([type])
}

// ============================================================
// PURCHASE ORDERS (Quote → PO)
// ============================================================

model PurchaseOrder {
  id              String              @id @default(cuid())
  poNumber        String              @unique
  quote           Quote?              @relation(fields: [quoteId], references: [id])
  quoteId         String?
  customer        Customer            @relation(fields: [customerId], references: [id])
  customerId      String
  status          PurchaseOrderStatus @default(DRAFT)
  subtotal        Float               @default(0)
  tax             Float               @default(0)
  total           Float               @default(0)
  deliveryAddress String?
  deliveryCity    String?
  projectName     String?
  clientPONumber  String?
  notes           String?
  approvedBy      User?               @relation("POApprovedBy", fields: [approvedById], references: [id])
  approvedById    String?
  approvedAt      DateTime?
  sentAt          DateTime?
  acceptedAt      DateTime?
  pdfUrl          String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  items      PurchaseOrderItem[]
  workOrders WorkOrder[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  description     String
  quantity        Float
  unitPrice       Float
  unit            String        @default("tonne")
  total           Float
  notes           String?

  @@index([purchaseOrderId])
}

// ============================================================
// WORK ORDERS (PO → Work Order, dispatched to drivers)
// ============================================================

model WorkOrder {
  id              String            @id @default(cuid())
  workOrderNumber String            @unique
  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String?
  status          WorkOrderStatus   @default(PENDING)
  priority        WorkOrderPriority @default(NORMAL)
  driver          Driver?           @relation(fields: [driverId], references: [id])
  driverId        String?
  equipment       Equipment?        @relation(fields: [equipmentId], references: [id])
  equipmentId     String?
  createdBy       User?             @relation("WOCreatedBy", fields: [createdById], references: [id])
  createdById     String?

  // Job details
  description     String?
  pickupLocation  String?
  deliveryAddress String?
  deliveryCity    String?
  deliveryContact String?
  deliveryPhone   String?
  scheduledDate   DateTime?
  scheduledTime   String?
  estimatedHours  Float?
  specialInstructions String?

  // Completion
  startedAt       DateTime?
  completedAt     DateTime?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  items   WorkOrderItem[]
  tickets Ticket[]

  @@index([status])
  @@index([driverId])
  @@index([scheduledDate])
  @@index([createdAt])
}

model WorkOrderItem {
  id          String    @id @default(cuid())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workOrderId String
  product     Product?  @relation(fields: [productId], references: [id])
  productId   String?
  description String
  quantity    Float
  unit        String    @default("tonne")
  notes       String?

  @@index([workOrderId])
}

// ============================================================
// TICKETS (Driver daily work records - SMS compatible)
// ============================================================

model Ticket {
  id            String       @id @default(cuid())
  ticketNumber  String       @unique
  workOrder     WorkOrder?   @relation(fields: [workOrderId], references: [id])
  workOrderId   String?
  driver        Driver       @relation(fields: [driverId], references: [id])
  driverId      String
  status        TicketStatus @default(DRAFT)
  date          DateTime     @default(now())

  // Time tracking
  startTime     String?
  endTime       String?
  hoursWorked   Float?
  breakHours    Float?      @default(0)

  // Distance tracking
  startKm       Float?
  endKm         Float?
  totalKm       Float?

  // Location
  jobSite       String?
  pickupSite    String?

  // SMS submission data
  rawSmsText    String?
  parsedBySms   Boolean     @default(false)

  // Review
  reviewedBy    User?       @relation("TicketReviewedBy", fields: [reviewedById], references: [id])
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?
  driverNotes   String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items         TicketItem[]
  equipmentUsed TicketEquipmentUsage[]
  invoice       Invoice?    @relation(fields: [invoiceId], references: [id])
  invoiceId     String?

  @@index([status])
  @@index([driverId])
  @@index([workOrderId])
  @@index([date])
  @@index([invoiceId])
}

model TicketItem {
  id          String  @id @default(cuid())
  ticket      Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    String
  product     Product? @relation(fields: [productId], references: [id])
  productId   String?
  description String
  quantity    Float
  unit        String  @default("tonne")
  unitPrice   Float   @default(0)
  total       Float   @default(0)
  notes       String?

  @@index([ticketId])
}

model TicketEquipmentUsage {
  id          String    @id @default(cuid())
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  equipmentId String
  hoursUsed   Float?
  kmDriven    Float?
  notes       String?

  @@index([ticketId])
  @@index([equipmentId])
}

// ============================================================
// INVOICES (Tickets → Invoice)
// ============================================================

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  customer        Customer      @relation(fields: [customerId], references: [id])
  customerId      String
  status          InvoiceStatus @default(DRAFT)

  // Financials
  subtotal        Float         @default(0)
  taxRate         Float         @default(0.05)
  tax             Float         @default(0)
  total           Float         @default(0)
  amountPaid      Float         @default(0)
  amountDue       Float         @default(0)

  // Terms
  issuedDate      DateTime?
  dueDate         DateTime?
  paymentTerms    String?       @default("Net 30")

  // Delivery
  deliveryAddress String?

  notes           String?
  internalNotes   String?
  pdfUrl          String?

  approvedBy      User?         @relation("InvoiceApprovedBy", fields: [approvedById], references: [id])
  approvedById    String?
  approvedAt      DateTime?
  sentAt          DateTime?
  viewedAt        DateTime?
  paidAt          DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items    InvoiceItem[]
  tickets  Ticket[]
  payments Payment[]

  @@index([status])
  @@index([customerId])
  @@index([dueDate])
  @@index([createdAt])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  description String
  quantity    Float
  unit        String  @default("tonne")
  unitPrice   Float
  total       Float
  ticketRef   String?
  notes       String?

  @@index([invoiceId])
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id            String        @id @default(cuid())
  paymentNumber String        @unique
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  invoiceId     String
  customer      Customer      @relation(fields: [customerId], references: [id])
  customerId    String
  amount        Float
  method        PaymentMethod
  reference     String?
  chequeNumber  String?
  depositDate   DateTime?
  notes         String?
  receivedAt    DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([invoiceId])
  @@index([customerId])
  @@index([receivedAt])
}
