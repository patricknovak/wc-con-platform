generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  MANAGER
  DISPATCHER
  VIEWER
}

enum CustomerType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  GOVERNMENT
}

enum QuoteStatus {
  DRAFT
  AI_GENERATED
  PENDING_REVIEW
  APPROVED
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum CallIntent {
  QUOTE_REQUEST
  INFORMATION
  DISPATCH_URGENT
  COMPLAINT
  FOLLOW_UP
  OTHER
}

enum CallPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CallStatus {
  NEW
  REVIEWED
  ACTIONED
  ARCHIVED
}

enum OpportunitySource {
  APC
  MERX
  CONSTRUCT_CONNECT
  MUNICIPAL
  ALBERTA_GOV
  MANUAL
}

enum OpportunityStatus {
  NEW
  STRONG_MATCH
  REVIEWING
  PURSUING
  PROPOSAL_DRAFTED
  SUBMITTED
  WON
  LOST
  EXPIRED
  ARCHIVED
}

enum ProposalStatus {
  DRAFTING
  AI_GENERATED
  UNDER_REVIEW
  FINALIZED
  SUBMITTED
  WON
  LOST
}

enum HubListingTier {
  FREE
  FEATURED
  PREMIUM
}

enum HubBusinessStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum DocumentType {
  QUOTE
  RFP
  PROPOSAL
  SUBMISSION
  INVOICE
  CONTRACT
  OTHER
}

enum ProductCategory {
  AGGREGATE
  LANDSCAPING
  CONCRETE
  EQUIPMENT
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(VIEWER)
  phone     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvedQuotes Quote[]    @relation("ApprovedBy")
  callActions    CallAction[]
}

// ============================================================
// CORE BUSINESS
// ============================================================

model Customer {
  id            String       @id @default(cuid())
  name          String
  email         String?
  phone         String
  company       String?
  type          CustomerType @default(RESIDENTIAL)
  address       String?
  city          String?
  province      String?      @default("AB")
  postalCode    String?
  notes         String?
  lifetimeValue Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  quotes     Quote[]
  phoneCalls PhoneCall[]

  @@index([type])
  @@index([city])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  category    ProductCategory
  description String?
  specs       String?
  sizeRange   String?
  commonUses  String?
  priceRange  String?
  unitOfMeasure String        @default("tonne")
  imageUrl    String?
  inStock     Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  quoteItems QuoteItem[]

  @@index([category])
}

model ServiceArea {
  id                String  @id @default(cuid())
  name              String
  description       String?
  deliverySurcharge Float   @default(0)
  polygon           Json?
  isActive          Boolean @default(true)
}

model Quote {
  id              String      @id @default(cuid())
  quoteNumber     String      @unique
  customer        Customer    @relation(fields: [customerId], references: [id])
  customerId      String
  status          QuoteStatus @default(DRAFT)
  subtotal        Float       @default(0)
  deliveryFee     Float       @default(0)
  tax             Float       @default(0)
  total           Float       @default(0)
  deliveryAddress String?
  deliveryCity    String?
  deliveryDistance Float?
  notes           String?
  aiDraft         String?
  approvedBy      User?       @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedById    String?
  approvedAt      DateTime?
  sentAt          DateTime?
  expiresAt       DateTime?
  pdfUrl          String?
  source          String?     @default("web")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items QuoteItem[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model QuoteItem {
  id        String  @id @default(cuid())
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Float
  unitPrice Float
  total     Float
  notes     String?

  @@index([quoteId])
}

// ============================================================
// VOICE AGENT (ElevenLabs + Twilio)
// ============================================================

model PhoneCall {
  id              String       @id @default(cuid())
  callerPhone     String
  callerName      String?
  callerEmail     String?
  callerCompany   String?
  intent          CallIntent   @default(OTHER)
  priority        CallPriority @default(MEDIUM)
  status          CallStatus   @default(NEW)
  transcript      String?
  summary         String?
  extractedData   Json?
  duration        Int?
  recordingUrl    String?
  agentId         String?
  twilioCallSid   String?      @unique
  customer        Customer?    @relation(fields: [customerId], references: [id])
  customerId      String?
  transferredToHuman Boolean   @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  actions CallAction[]

  @@index([status])
  @@index([intent])
  @@index([createdAt])
  @@index([callerPhone])
}

model CallAction {
  id          String   @id @default(cuid())
  call        PhoneCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  callId      String
  actionType  String
  description String?
  assignedTo  User?    @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([callId])
}

// ============================================================
// BUSINESS HUB
// ============================================================

model HubCategory {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  icon        String?
  sortOrder   Int           @default(0)
  businesses  HubBusiness[]
}

model HubBusiness {
  id            String            @id @default(cuid())
  name          String
  slug          String            @unique
  description   String?
  longDescription String?
  logoUrl       String?
  coverImageUrl String?
  phone         String?
  email         String?
  website       String?
  address       String?
  city          String?           @default("Hinton")
  province      String?           @default("AB")
  serviceAreas  String[]
  category      HubCategory       @relation(fields: [categoryId], references: [id])
  categoryId    String
  tier          HubListingTier    @default(FREE)
  status        HubBusinessStatus @default(PENDING)
  featured      Boolean           @default(false)
  referralCode  String?           @unique
  contactName   String?
  approvedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  referralsOut HubReferral[] @relation("SourceBusiness")
  referralsIn  HubReferral[] @relation("DestinationBusiness")

  @@index([status])
  @@index([categoryId])
  @@index([featured])
  @@index([city])
}

model HubReferral {
  id            String       @id @default(cuid())
  source        HubBusiness  @relation("SourceBusiness", fields: [sourceId], references: [id])
  sourceId      String
  destination   HubBusiness  @relation("DestinationBusiness", fields: [destinationId], references: [id])
  destinationId String
  visitorId     String?
  converted     Boolean      @default(false)
  revenue       Float?
  createdAt     DateTime     @default(now())

  @@index([sourceId])
  @@index([destinationId])
  @@index([createdAt])
}

// ============================================================
// OPPORTUNITY ENGINE
// ============================================================

model Opportunity {
  id              String            @id @default(cuid())
  externalId      String?           @unique
  source          OpportunitySource
  title           String
  description     String?
  fullText        String?
  category        String?
  location        String?
  estimatedValue  Float?
  deadline        DateTime?
  publishedAt     DateTime?
  documentUrl     String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  matchScore      Int               @default(0)
  scoreBreakdown  Json?
  capabilityTags  String[]
  status          OpportunityStatus @default(NEW)
  notifiedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  proposals Proposal[]

  @@index([status])
  @@index([matchScore])
  @@index([deadline])
  @@index([source])
  @@index([createdAt])
}

model Proposal {
  id            String         @id @default(cuid())
  opportunity   Opportunity    @relation(fields: [opportunityId], references: [id])
  opportunityId String
  status        ProposalStatus @default(DRAFTING)
  aiDraft       String?
  finalVersion  String?
  coverLetter   String?
  pdfUrl        String?
  submittedAt   DateTime?
  outcome       String?
  outcomeNotes  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([opportunityId])
  @@index([status])
}

// ============================================================
// INTELLIGENCE LAYER
// ============================================================

model HistoricalDocument {
  id            String       @id @default(cuid())
  type          DocumentType
  fileName      String
  fileUrl       String?
  fileSize      Int?
  extractedData Json?
  extractedText String?
  embedding     Unsupported("vector(1536)")?
  processedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([type])
}

model PricingDataPoint {
  id           String   @id @default(cuid())
  productName  String
  productCategory String?
  quantity     Float
  unitPrice    Float
  totalPrice   Float?
  distance     Float?
  customerName String?
  customerType CustomerType?
  date         DateTime
  outcome      String?
  source       String?
  createdAt    DateTime @default(now())

  @@index([productName])
  @@index([date])
  @@index([outcome])
}

// ============================================================
// CONTENT
// ============================================================

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  client      String?
  location    String?
  category    String?
  services    String[]
  images      String[]
  featured    Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
  @@index([category])
}

model Testimonial {
  id          String   @id @default(cuid())
  authorName  String
  authorTitle String?
  company     String?
  content     String
  rating      Int?     @default(5)
  featured    Boolean  @default(false)
  imageUrl    String?
  createdAt   DateTime @default(now())

  @@index([featured])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String?  @default("WC-CON Team")
  tags        String[]
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([publishedAt])
}

// ============================================================
// NOTIFICATIONS & ACTIVITY
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  data      Json?
  read      Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  @@index([read])
  @@index([userId])
  @@index([createdAt])
}
